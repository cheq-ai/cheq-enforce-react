{
    "name": "@cheq.ai/cheq-enforce-react",
    "version": "0.0.1",
    "description": "CHEQ Enforce consent management SDK for React and React Native applications",
    "author": "CHEQ AI Technologies <tms+npm@cheq.ai>",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cheq-ai/cheq-enforce-react.git"
    },
    "bugs": {
        "url": "https://github.com/cheq-ai/cheq-enforce-react/issues"
    },
    "homepage": "https://github.com/cheq-ai/cheq-enforce-react#readme",
    "keywords": [
        "cheq",
        "enforce",
        "consent",
        "privacy",
        "gdpr",
        "ccpa",
        "react",
        "react-native"
    ],
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "react-native": "./dist/index.js",
    "files": [
        "dist",
        "README.md"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "tsup && cp -f ../../README.md ./README.md",
        "dev": "tsup --watch",
        "prepare": "npm run build",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "react-native": "./dist/index.native.js",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "default": "./dist/index.js"
        }
    },
    "peerDependencies": {
        "@react-native-async-storage/async-storage": ">=2.1.2",
        "react": ">=17",
        "react-native": ">=0.70"
    },
    "peerDependenciesMeta": {
        "@react-native-async-storage/async-storage": {
            "optional": true
        },
        "react-native": {
            "optional": true
        }
    },
    "devDependencies": {
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.0.10",
        "@types/react": "^19.0.0",
        "@types/react-native": "^0.73.0",
        "happy-dom": "^20.9.0",
        "jsdom": "^29.1.1",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "vitest": "^4.1.6"
    },
    "dependencies": {
        "lz4js": "^0.2.0"
    }
}
