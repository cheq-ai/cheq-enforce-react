{
    "name": "cheq-enforce-react",
    "version": "0.1.0",
    "description": "Consent SDK for React, React Native, and Web. Web uses localStorage; native consumers must install @react-native-async-storage/async-storage for persistence.",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "npx tsup",
        "dev": "npx tsup --watch",
        "prepare": "npm run build",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "react-native": "./dist/index.native.js",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "default": "./dist/index.js"
        }
    },
    "peerDependencies": {
        "@react-native-async-storage/async-storage": ">=2.1.2",
        "react": ">=17",
        "react-native": ">=0.70"
    },
    "peerDependenciesMeta": {
        "@react-native-async-storage/async-storage": {
            "optional": true
        },
        "react-native": {
            "optional": true
        }
    },
    "devDependencies": {
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.0.10",
        "@types/react": "^19.0.0",
        "@types/react-native": "^0.73.0",
        "happy-dom": "^20.9.0",
        "jsdom": "^29.1.1",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "vitest": "^4.1.6"
    },
    "dependencies": {
        "lz4js": "^0.2.0"
    }
}
