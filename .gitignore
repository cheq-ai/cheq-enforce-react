# Dependencies
node_modules/

# Workspace lockfile strategy
# Keep the root workspace lockfile committed; ignore nested lockfiles.
source/*/package-lock.json
sample-app/*/package-lock.json

# Build outputs
dist/
build/
coverage/
.nyc_output/
*.tsbuildinfo

# Expo / Metro
.expo/
.expo-shared/
.metro-cache/

# Android / Gradle
android/.gradle/
android/build/
android/app/build/
android/.kotlin/
android/app/.cxx/
android/local.properties
sample-app/*/android/.gradle/
sample-app/*/android/build/
sample-app/*/android/app/build/
sample-app/*/android/.kotlin/
sample-app/*/android/app/.cxx/
sample-app/*/android/local.properties
*.keystore
*.jks
!sample-app/*/android/app/debug.keystore

# iOS / Xcode
ios/build/
sample-app/*/ios/build/
DerivedData/
*.xcuserstate
**/xcuserdata/
sample-app/*/ios/.xcode.env.local

# CocoaPods
ios/Pods/
sample-app/*/ios/Pods/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# NPM pack output
*.tgz

# Temporary files
tmp/
temp/
